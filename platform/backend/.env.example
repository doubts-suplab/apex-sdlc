DATABASE_URL=postgresql+asyncpg://apex:apex_dev@localhost:5432/apex_platform
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
LOG_LEVEL=INFO

# -----------------------------------------------------------------------
# LLM Provider (choose one: stub | anthropic | ollama | groq | huggingface)
#   stub = deterministic, offline, no API key — powers the reference journey + demo
# -----------------------------------------------------------------------
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-5

# Anthropic (set LLM_PROVIDER=anthropic to use)
ANTHROPIC_API_KEY=sk-ant-...

# Ollama (local LLMs — set LLM_PROVIDER=ollama to use)
OLLAMA_BASE_URL=http://localhost:11434

# Groq (set LLM_PROVIDER=groq to use)
GROQ_API_KEY=gsk_...

# HuggingFace (set LLM_PROVIDER=huggingface to use)
HUGGINGFACE_TOKEN=hf_...

# -----------------------------------------------------------------------
# GitHub
# -----------------------------------------------------------------------
GITHUB_TOKEN=ghp_...

# -----------------------------------------------------------------------
# Jira
# -----------------------------------------------------------------------
JIRA_BASE_URL=https://myorg.atlassian.net
JIRA_EMAIL=service@myorg.com
JIRA_API_TOKEN=...

# -----------------------------------------------------------------------
# Rally (CA Agile Central) — alternative to Jira
# -----------------------------------------------------------------------
RALLY_BASE_URL=https://rally1.rallydev.com
RALLY_API_KEY=_abc123...
RALLY_WORKSPACE_OID=12345678

# -----------------------------------------------------------------------
# Confluence
# -----------------------------------------------------------------------
CONFLUENCE_BASE_URL=https://myorg.atlassian.net/wiki
CONFLUENCE_TOKEN=...
CONFLUENCE_EMAIL=service@myorg.com

# -----------------------------------------------------------------------
# S3 / Storage
# -----------------------------------------------------------------------
S3_ARTIFACT_BUCKET=apex-artifacts-dev
AWS_REGION=eu-west-1
